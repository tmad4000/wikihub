{
  "name": "@wikihub/mcp-server",
  "version": "0.1.0",
  "description": "Model Context Protocol server for WikiHub — lets Claude / ChatGPT / any MCP client search, read, and write wiki pages via the WikiHub API.",
  "type": "module",
  "private": true,
  "bin": {
    "wikihub-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "dev": "tsc --watch",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "wikihub",
    "wiki",
    "claude",
    "chatgpt"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^4.21.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
