{
  "name": "wikihub",
  "productName": "WikiHub",
  "version": "1.0.0",
  "description": "Desktop app for WikiHub — GitHub for LLM wikis",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "build:dmg": "electron-builder --mac dmg",
    "build:zip": "electron-builder --mac zip"
  },
  "build": {
    "appId": "com.wikihub.desktop",
    "productName": "WikiHub",
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.productivity",
      "target": ["dmg", "zip"]
    },
    "files": [
      "main.js",
      "preload.js",
      "tray.js",
      "assets/**/*"
    ]
  },
  "devDependencies": {
    "electron": "35.1.5",
    "electron-builder": "26.0.12"
  },
  "dependencies": {
    "electron-store": "8.2.0"
  }
}
