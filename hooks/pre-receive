#!/usr/bin/env python3
import os
import subprocess
import sys


def read_config():
    conf_path = os.path.join(os.path.dirname(os.path.abspath(__file__)), "wikihub.conf")
    config = {}
    if os.path.isfile(conf_path):
        with open(conf_path) as handle:
            for line in handle:
                line = line.strip()
                if "=" in line and not line.startswith("#"):
                    key, value = line.split("=", 1)
                    config[key.strip()] = value.strip()
    return config


def read_file_content(sha, filepath, repo_dir):
    result = subprocess.run(
        ["git", "show", f"{sha}:{filepath}"],
        capture_output=True,
        text=True,
        cwd=repo_dir,
    )
    if result.returncode != 0:
        return None
    return result.stdout


def main():
    config = read_config()
    app_root = config.get("WIKIHUB_APP_ROOT")
    if app_root and app_root not in sys.path:
        sys.path.insert(0, app_root)

    from app.acl import validate_acl

    repo_dir = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
    null_sha = "0" * 40

    for line in sys.stdin:
        parts = line.strip().split()
        if len(parts) < 3:
            continue
        _, new_sha, refname = parts
        if refname not in ("refs/heads/main", "refs/heads/master") or new_sha == null_sha:
            continue

        acl_text = read_file_content(new_sha, ".wikihub/acl", repo_dir)
        if acl_text is None:
            continue

        errors = validate_acl(acl_text)
        if errors:
            print("Push rejected: malformed .wikihub/acl", file=sys.stderr)
            for error in errors:
                print(f"  - {error}", file=sys.stderr)
            return 1

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
